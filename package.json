{
  "name": "eyeballs",
  "version": "0.1.0",
  "description": "Visual monitoring for AI agents and humans. CLI + MCP server.",
  "type": "module",
  "bin": {
    "eyeballs": "./dist/cli.js",
    "eyeballs-mcp": "./dist/mcp.js"
  },
  "main": "./dist/core.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start:mcp": "node dist/mcp.js",
    "start:cli": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "npx playwright install chromium",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "ai",
    "visual-monitoring",
    "screenshot",
    "diff",
    "pixel-diff",
    "eyeballs",
    "playwright"
  ],
  "author": "Dane Hesseldahl",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.49.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
